DATABASE_URL=file:./db/custom.db

# NextAuth (required for magic-link auth)
# Generate a random string: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# Email server (Resend or any SMTP). Leave empty for dev — NextAuth logs the magic link to the server console.
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=465
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=AuditGPT <login@auditgpt.ai>

# Stripe (leave empty to disable live checkout — pricing page shows a config warning instead)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CLIENT_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# AuditGPT pricing doctrine SKUs. Create these Prices in the Stripe Dashboard,
# then paste each Price ID (price_...) into the matching env var below.
# The amount on each Stripe Price MUST match the public price shown on /pricing.
#   - "Claim Intelligence Report" — $299 one-time payment
#   - "Claim Drift Monitoring" — $299/month recurring
#   - "Agency Founding Beta" — $499/month recurring (first 5 partners — current active agency checkout)
#   - "Agency Partner Plan" — $799/month recurring (standard rate after the founding cohort fills)
NEXT_PUBLIC_STRIPE_CLAIM_INTELLIGENCE_REPORT_299=
NEXT_PUBLIC_STRIPE_CLAIM_DRIFT_MONITORING_299_MONTHLY=
NEXT_PUBLIC_STRIPE_AGENCY_FOUNDING_BETA_499_MONTHLY=
NEXT_PUBLIC_STRIPE_AGENCY_PARTNER_799_MONTHLY=

# Token encryption for stored OAuth credentials (Stripe Connect, future GA, etc.)
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=your-64-char-hex-key-here

# Public URL (used for Stripe success/cancel URLs and OG tags)
NEXT_PUBLIC_URL=http://localhost:3000

# Audit provider routing. Defaults to "zai" (the current live provider).
# Switch to "openai", "anthropic", or "deepseek" by changing LLM_PROVIDER
# and setting the matching API key. The audit pipeline calls through
# src/lib/llm-provider.ts so the switch is one env var.
LLM_PROVIDER=zai

# Provider keys (set the one matching LLM_PROVIDER)
Z_AI_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Generate with: openssl rand -hex 32
RATE_LIMIT_SALT=your-64-char-random-hex-value
# Shared by the scheduler and /api/cron/expire-claims
CRON_SECRET=your-64-char-random-hex-value

# CI check API key — used by /api/ci/check for pre-deploy gates
CI_API_KEY=your-ci-api-key-string

# GitHub OAuth for fix deployment + sign-in
# Registered as a GitHub OAuth App: Settings → Developer settings → OAuth Apps
# Homepage URL: http://localhost:3000
# Callback URLs (add both):
#   - http://localhost:3000/api/integrations/github/callback  (deploy fixes)
#   - http://localhost:3000/api/auth/callback/github          (NextAuth sign-in)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth for sign-in
# Register at Google Cloud Console → APIs & Services → Credentials → OAuth client ID
# Authorized redirect URIs:
#   - http://localhost:3000/api/auth/callback/google
#   - https://auditgpt.ai/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
